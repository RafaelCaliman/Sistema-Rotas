Options -Indexes

RewriteEngine On
RewriteBase /hotdog-brasilia/

# Serve arquivos estáticos diretamente quando existirem
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Define o index como public/index.php
DirectoryIndex public/index.php

# Roteia o restante para o front controller
RewriteRule ^(.*)$ public/index.php [L,QSA]